{
  "easycom": {
    "autoscan": true,
    "custom": {
      "^w-(.*)": "@/components/w-$1/w-$1.vue"
    }
  },
  "pages": [
    {
      "path": "pages/index/index",
      "style": {
        "navigationBarTitleText": "味真足",
        "navigationStyle": "custom",
        "enablePullDownRefresh": false
      }
    },
    {
      "path": "pages/login/login",
      "style": {
        "navigationBarTitleText": "登录",
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/merchant/list",
      "style": {
        "navigationBarTitleText": "商家列表"
      }
    },
    {
      "path": "pages/merchant/detail",
      "style": {
        "navigationBarTitleText": "商家详情"
      }
    },
    {
      "path": "pages/dish/detail",
      "style": {
        "navigationBarTitleText": "菜品详情"
      }
    },
    {
      "path": "pages/cart/index",
      "style": {
        "navigationBarTitleText": "购物车"
      }
    },
    {
      "path": "pages/order/checkout",
      "style": {
        "navigationBarTitleText": "确认订单"
      }
    },
    {
      "path": "pages/order/list",
      "style": {
        "navigationBarTitleText": "我的订单"
      }
    },
    {
      "path": "pages/order/detail",
      "style": {
        "navigationBarTitleText": "订单详情"
      }
    },
    {
      "path": "pages/order/payment",
      "style": {
        "navigationBarTitleText": "收银台"
      }
    },
    {
      "path": "pages/order/result",
      "style": {
        "navigationBarTitleText": "支付结果",
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/order/refund",
      "style": {
        "navigationBarTitleText": "申请退款"
      }
    },
    {
      "path": "pages/address/list",
      "style": {
        "navigationBarTitleText": "收货地址"
      }
    },
    {
      "path": "pages/address/edit",
      "style": {
        "navigationBarTitleText": "编辑地址"
      }
    },
    {
      "path": "pages/profile/index",
      "style": {
        "navigationBarTitleText": "我的"
      }
    },
    {
      "path": "pages/settings/index",
      "style": {
        "navigationBarTitleText": "设置",
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/coupon/index",
      "style": {
        "navigationBarTitleText": "优惠券"
      }
    },
    {
      "path": "pages/message/index",
      "style": {
        "navigationBarTitleText": "消息中心"
      }
    },
    {
      "path": "pages/search/index",
      "style": {
        "navigationBarTitleText": "搜索"
      }
    }
  ],
  "globalStyle": {
    "navigationBarTextStyle": "black",
    "navigationBarTitleText": "味真足",
    "navigationBarBackgroundColor": "#FFFFFF",
    "backgroundColor": "#F5F5F7",
    "backgroundTextStyle": "light"
  },
  "tabBar": {
    "custom": true,
    "color": "#999999",
    "selectedColor": "#333333",
    "backgroundColor": "#FFFFFF",
    "borderStyle": "black",
    "list": [
      {
        "pagePath": "pages/index/index",
        "text": "外卖"
      },
      {
        "pagePath": "pages/coupon/index",
        "text": "神券"
      },
      {
        "pagePath": "pages/order/list",
        "text": "订单"
      },
      {
        "pagePath": "pages/profile/index",
        "text": "我的"
      }
    ]
  }
}
